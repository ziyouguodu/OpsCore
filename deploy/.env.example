POSTGRES_DB=opscore
POSTGRES_USER=opscore
POSTGRES_PASSWORD=change-me-postgres-password

POSTGRES_PORT=5432
BACKEND_PORT=8080
FRONTEND_PORT=5173

OPSCORE_JWT_SECRET=change-this-in-production
OPSCORE_CREDENTIAL_ENCRYPTION_KEY=change-this-credential-key-32bytes
OPSCORE_INITIAL_ADMIN_PASSWORD=ChangeMe123!
OPSCORE_CORS_ORIGIN=http://localhost:5173

# Docker Compose 前端默认通过 Nginx 反代访问后端。远程独立部署静态前端时可改成 https://api.example.com/api
VITE_API_BASE=/api
VITE_ENABLE_DEMO_DATA=false
